[Unit]
Description=Modbus TCP Poller for Furnace (Slave 6)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/srv/docker/apps/energy-tracker
EnvironmentFile=/srv/docker/apps/energy-tracker/.env.slave6
ExecStart=/usr/bin/python3 /srv/docker/apps/energy-tracker/modbus_poller.py
Restart=always
RestartSec=5
StandardOutput=append:/var/log/poller-slave6.log
StandardError=append:/var/log/poller-slave6.log

[Install]
WantedBy=multi-user.target
