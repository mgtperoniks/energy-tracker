[Unit]
Description=Modbus TCP Poller for Bahan Baku (Slave 1)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/srv/docker/apps/energy-tracker
EnvironmentFile=/srv/docker/apps/energy-tracker/.env.slave1
ExecStart=/usr/bin/python3 /srv/docker/apps/energy-tracker/modbus_poller.py
Restart=always
RestartSec=5
StandardOutput=append:/var/log/poller-slave1.log
StandardError=append:/var/log/poller-slave1.log

[Install]
WantedBy=multi-user.target
